<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>The Cultural Brief (SA) — {{ date }}</title>
  <meta name="description" content="{{ og_description }}"/>
  <meta property="og:title" content="{{ title }} — The Cultural Brief (SA)"/>
  <meta property="og:description" content="{{ og_description }}"/>
  <meta property="og:type" content="article"/>
  <meta property="og:url" content="https://1906reblabs.github.io/cultural-brief-sa/editions/{{ slug }}.html"/>
  <meta property="og:image" content="https://1906reblabs.github.io/cultural-brief-sa/og-images/og-{{ slug }}.svg"/>
  <meta property="og:image:width" content="1200"/>
  <meta property="og:image:height" content="630"/>
  <meta property="article:published_time" content="{{ iso_date }}"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content="{{ title }} — The Cultural Brief (SA)"/>
  <meta name="twitter:description" content="{{ og_description }}"/>
  <meta name="twitter:image" content="https://1906reblabs.github.io/cultural-brief-sa/og-images/og-{{ slug }}.svg"/>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
  <style>
    :root{--ink:#1a1714;--paper:#f5f2ec;--muted:#7a7167;--rule:#c9c3b8;--accent:#2c2c2c;}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    html{font-size:18px;scroll-behavior:smooth;-webkit-text-size-adjust:100%;}
    body{background-color:var(--paper);color:var(--ink);font-family:'EB Garamond',Georgia,serif;line-height:1.75;min-height:100vh;display:flex;flex-direction:column;overflow-x:hidden;}
    body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:0;opacity:0.5;}
    .container{max-width:680px;margin:0 auto;padding:0 2rem;width:100%;position:relative;z-index:1;}
    /* ── MASTHEAD ── */
    .masthead{border-bottom:3px double var(--ink);padding:2.4rem 2rem 1.8rem;text-align:center;animation:fadeDown 0.9s ease both;}
    .masthead-nav{font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);margin-bottom:1.4rem;}
    .masthead-nav a{color:var(--muted);text-decoration:none;border-bottom:1px solid var(--rule);padding-bottom:1px;transition:color 0.2s;}
    .masthead-nav a:hover{color:var(--ink);}
    .masthead h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,5vw,3rem);font-weight:700;letter-spacing:-0.01em;line-height:1.1;color:var(--ink);}
    .masthead h1 em{font-style:italic;font-weight:400;}
    .masthead-rule{display:flex;align-items:center;justify-content:center;gap:1rem;margin:1.2rem 0 1rem;}
    .masthead-rule span{display:block;height:1px;width:60px;background:var(--rule);}
    .masthead-rule .ornament{font-size:0.75rem;color:var(--muted);letter-spacing:0.15em;}
    .masthead-meta{font-size:0.7rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);}
    /* ── MAIN ── */
    main{flex:1;padding:3.5rem 0 6rem;animation:fadeUp 0.9s ease 0.15s both;}
    /* ── EDITION HEADER ── */
    .edition-header{border-bottom:1px solid var(--rule);padding-bottom:2.4rem;margin-bottom:3rem;}
    .edition-kicker{font-size:0.68rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;}
    .edition-title{font-family:'Playfair Display',serif;font-size:clamp(1.7rem,4.5vw,2.6rem);font-weight:400;font-style:italic;line-height:1.2;color:var(--ink);margin-bottom:1.2rem;}
    .edition-standfirst{font-size:1.05rem;color:var(--accent);font-style:italic;line-height:1.65;border-left:2px solid var(--rule);padding-left:1.2rem;margin-bottom:1.8rem;}
    /* ── QUOTE ── */
    .opening-quote{margin:0 0 3rem;padding:1.6rem 0 1.6rem 1.4rem;border-left:2px solid var(--ink);}
    .opening-quote blockquote{font-family:'Playfair Display',serif;font-style:italic;font-size:1.05rem;line-height:1.6;color:var(--ink);margin-bottom:0.6rem;}
    .opening-quote cite{font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);font-style:normal;}
    /* ── PROSE ── */
    p{margin-bottom:1.4rem;}
    p:last-child{margin-bottom:0;}
    /* ── SECTION LABEL ── */
    .section-label{font-size:0.68rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--muted);margin:3.5rem 0 1.8rem;display:flex;align-items:center;gap:1.2rem;}
    .section-label::after{content:'';flex:1;height:1px;background:var(--rule);}
    /* ── CULTURAL SIGNAL ── */
    .cultural-signal{background:transparent;border-top:2px solid var(--ink);border-bottom:1px solid var(--rule);padding:1.8rem 0;margin-bottom:3rem;}
    .cultural-signal p{font-family:'Playfair Display',serif;font-size:1.1rem;font-style:italic;line-height:1.6;color:var(--ink);margin:0;}
    /* ── DISPATCHES ── */
    .dispatch{margin-bottom:3rem;padding-bottom:3rem;border-bottom:1px solid var(--rule);}
    .dispatch:last-of-type{border-bottom:none;}
    .dispatch h3{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:400;font-style:italic;line-height:1.3;margin-bottom:0.5rem;color:var(--ink);}
    .dispatch-meta{font-size:0.68rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;}
    .dispatch-footer{font-size:0.82rem;color:var(--muted);margin-top:1rem;font-style:italic;}
    /* ── LONG ESSAY ── */
    .long-essay{margin:4rem 0;}
    .long-essay-label{font-size:0.68rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--muted);margin-bottom:1.4rem;display:flex;align-items:center;gap:1.2rem;}
    .long-essay-label::after{content:'';flex:1;height:1px;background:var(--rule);}
    .long-essay h2{font-family:'Playfair Display',serif;font-size:clamp(1.4rem,3.5vw,2rem);font-weight:700;line-height:1.2;margin-bottom:1.4rem;color:var(--ink);}
    .essay-body p{margin-bottom:1.5rem;font-size:1rem;}
    .essay-body p:first-child::first-letter{font-family:'Playfair Display',serif;font-size:3.2rem;line-height:0.85;float:left;margin-right:0.1em;margin-top:0.1em;color:var(--ink);}
    /* ── CLOSING ── */
    .closing{margin-top:4rem;padding-top:2.4rem;border-top:3px double var(--ink);}
    .closing-label{font-size:0.68rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--muted);margin-bottom:1.4rem;}
    .closing p{font-size:0.96rem;color:var(--accent);font-style:italic;line-height:1.75;}
    /* ── SIGNOFF ── */
    .signoff{text-align:center;margin-top:3.5rem;padding-top:2rem;border-top:1px solid var(--rule);}
    .signoff p{font-family:'EB Garamond',serif;font-style:italic;font-size:0.95rem;color:var(--muted);}
    /* ── FOOTER ── */
    footer{border-top:1px solid var(--rule);padding:2rem;text-align:center;position:relative;z-index:1;}
    footer p{font-family:'EB Garamond',serif;font-style:italic;font-size:0.85rem;color:var(--muted);}
    footer a{color:var(--muted);text-decoration:none;border-bottom:1px solid var(--rule);}
    footer a:hover{color:var(--ink);}
    /* ── ANIMATIONS ── */
    @keyframes fadeDown{from{opacity:0;transform:translateY(-14px);}to{opacity:1;transform:translateY(0);}}
    @keyframes fadeUp{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
    /* ── RESPONSIVE ── */
    @media(max-width:600px){
      .masthead{padding:1.8rem 1.2rem 1.4rem;}
      .container{padding:0 1.2rem;}
      .opening-quote{padding-left:1rem;}
    }
    @media(prefers-reduced-motion:reduce){*{animation-duration:0.01ms!important;transition-duration:0.01ms!important;}}
  </style>
</head>
<body>

<header class="masthead">
  <div class="container">
    <p class="masthead-nav"><a href="../index.html">&larr; All Editions</a></p>
    <h1>The Cultural Brief <em>(SA)</em></h1>
    <div class="masthead-rule"><span></span><span class="ornament">&#10022;</span><span></span></div>
    <p class="masthead-meta">South Africa &nbsp;·&nbsp; Cultural Intelligence &nbsp;·&nbsp; {{ date }}</p>
  </div>
</header>

<main>
  <div class="container">

    <div class="edition-header">
      <p class="edition-kicker">Edition &nbsp;·&nbsp; {{ date }}</p>
      <h1 class="edition-title">{{ title }}</h1>
      <p class="edition-standfirst">{{ standfirst }}</p>
    </div>

    <div class="opening-quote">
      <blockquote>&#8220;{{ opening_quote.text }}&#8221;</blockquote>
      <cite>— {{ opening_quote.author }}{% if opening_quote.source %}, <em>{{ opening_quote.source }}</em>{% endif %}</cite>
    </div>

    {% for para in lead_paragraphs %}
    <p>{{ para }}</p>
    {% endfor %}

    <div class="cultural-signal">
      <p>{{ cultural_signal }}</p>
    </div>

    <p class="section-label">Curated Dispatches</p>

    {% for d in dispatches %}
    <div class="dispatch">
      <h3>{{ d.title }}</h3>
      <p class="dispatch-meta">{{ d.meta }}</p>
      {% for para in d.body_paragraphs %}
      <p>{{ para }}</p>
      {% endfor %}
      <p class="dispatch-footer">{{ d.footer }}</p>
    </div>
    {% endfor %}

    <div class="long-essay">
      <p class="long-essay-label">Long Essay</p>
      <h2>{{ essay.title }}</h2>
      <div class="essay-body">
        {% for para in essay.paragraphs %}
        <p>{{ para }}</p>
        {% endfor %}
      </div>
    </div>

    <div class="closing">
      <p class="closing-label">Closing Reflection</p>
      {% for para in closing_paragraphs %}
      <p{% if not loop.first %} style="margin-top:1rem;"{% endif %}>{{ para }}</p>
      {% endfor %}
    </div>

    <div class="signoff">
      <p><em>One edition. Every Thursday. Thank you for reading.</em></p>
    </div>

  </div>
</main>

<footer>
  <p>The Cultural Brief (SA) is published weekly at <a href="https://1906reblabs.github.io/cultural-brief-sa/">1906reblabs.github.io/cultural-brief-sa</a></p>
</footer>

<script src="../cookie-consent.js"></script>
</body>
</html>
